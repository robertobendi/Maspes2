{% extends '@theme/layout.twig' %}

{% set active_page = 'su-misura' %}

{% block title %}Composizioni su misura — Maspes Piante e Fiori{% endblock %}
{% block meta_description %}Matrimoni, eventi, hotel e regali importanti. Raccontaci l'occasione: ascoltiamo, disegniamo, consegniamo a Como e provincia. Maspes Piante e Fiori, dal 1954.{% endblock %}

{% block content %}

{# ============================== HERO ============================== #}
<section class="hero-split" aria-label="Composizioni su misura">
    <div class="photo" aria-hidden="true" style="order: 2;">
        <img src="/uploads/wedding/church_on_the_morning_of_the_wedding__unsplash__jpg.jpg"
             alt=""
             loading="eager" decoding="async">
    </div>
    <div class="copy" style="order: 1;">
        <p class="eyebrow on-dark">Su misura</p>
        <h1 class="display">Composizioni su&nbsp;misura.</h1>
        <p class="subhead">Matrimoni, eventi, hotel &amp; ristoranti, regali importanti. Pensate insieme a voi, realizzate a mano in negozio, consegnate a Como e provincia.</p>
        <div class="cta-row">
            <a href="#richiesta" class="btn btn-primary">Raccontaci l'occasione <span class="arrow" aria-hidden="true">→</span></a>
            <span class="phone-line">o telefonate al <a href="tel:+39031271136">031 27 11 36</a></span>
        </div>
    </div>
    <div class="hero-rule" aria-hidden="true">
        <span class="line"></span>
        <span class="mark">
            <svg width="40" height="48" viewBox="0 0 40 48" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M2 47V20a18 18 0 0 1 36 0v27" stroke-linecap="round"/>
                <path d="M20 2v45M2 32h36" stroke-linecap="round"/>
            </svg>
        </span>
        <span class="line"></span>
    </div>
</section>

{# ============================== PROCESS STRIP ============================== #}
<section class="section surface-avorio">
    <div class="container">
        <p class="eyebrow on-light center">Come lavoriamo</p>
        <h2 class="center" style="max-width: 20ch; margin-inline: auto; margin-bottom: 3.5rem;">Tre passaggi, in mano nostra.</h2>
        <div class="process">
            <div class="step reveal">
                <span class="num">01</span>
                <p class="name">Ascoltiamo</p>
                <p>Una telefonata o una visita in negozio. Ci raccontate l'occasione, il luogo, le persone — annotiamo tutto.</p>
            </div>
            <div class="step reveal">
                <span class="num">02</span>
                <p class="name">Disegniamo</p>
                <p>Vi proponiamo una composizione, scelta di fiori e palette. Aggiustiamo finché non corrisponde a ciò che immaginate.</p>
            </div>
            <div class="step reveal">
                <span class="num">03</span>
                <p class="name">Consegniamo</p>
                <p>Realizzata a mano la mattina stessa, consegnata da noi a Como e provincia, all'orario che ci avete chiesto.</p>
            </div>
        </div>
    </div>
</section>

{# ============================== REFERENCE PAIR ============================== #}
<section class="section surface-bosco">
    <div class="container">
        <p class="eyebrow on-dark center">Alcuni lavori</p>
        <div class="ref-pair" style="margin-top: 2.5rem;">
            <figure class="reveal">
                <img src="/uploads/composizioni/dark_rose_close_up_jpg.jpg" alt="Composizione di rose scure, dettaglio di una proposta per cerimonia.">
                <figcaption>Matrimonio</figcaption>
            </figure>
            <figure class="reveal">
                <img src="/uploads/composizioni/anna_maria_janssens_or_jan_brueghel_the_younger__workshop___.jpg" alt="Bouquet a tavolo in stile fiammingo per allestimento di hotel di lago.">
                <figcaption>Hotel &amp; Ristorante</figcaption>
            </figure>
        </div>
    </div>
</section>

{# ============================== FORM ============================== #}
<section class="section surface-avorio" id="richiesta">
    <div class="container">
        <div class="form-grid">
            <div class="intro">
                <p class="eyebrow on-light">Richiesta su misura</p>
                <h2>Raccontaci la tua occasione.</h2>
                <p>Più dettagli ci dai, più mirata sarà la nostra proposta. Rispondiamo entro il giorno lavorativo successivo.</p>
                <div class="alt">
                    <span class="label">In alternativa</span>
                    <p class="phone"><a href="tel:+39031271136">031 27 11 36</a></p>
                    <p style="margin-top:.5rem; color: var(--ink-carbone-soft); font-size:0.9rem;">Lun–Sab in orario di apertura. <a href="/visitaci" class="link-brass">Vedi gli orari</a></p>
                </div>
            </div>
            <div>
                <!-- TODO: replace REPLACE_ME with the Formspree endpoint once the account is created. Form posts go to info@maspespiantefiori.it. -->
                <form action="https://formspree.io/f/REPLACE_ME" method="POST">
                    <input type="hidden" name="_subject" value="Nuova richiesta su misura — maspespiantefiori.it">
                    <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;">

                    <div class="form-row-2">
                        <div class="field">
                            <label for="nome">Nome e cognome</label>
                            <input id="nome" name="nome" type="text" required autocomplete="name">
                        </div>
                        <div class="field">
                            <label for="email">Email</label>
                            <input id="email" name="email" type="email" required autocomplete="email">
                        </div>
                    </div>

                    <div class="form-row-2">
                        <div class="field">
                            <label for="telefono">Telefono</label>
                            <input id="telefono" name="telefono" type="tel" autocomplete="tel">
                        </div>
                        <div class="field">
                            <label for="occasione">Occasione</label>
                            <select id="occasione" name="occasione" required>
                                <option value="">Seleziona…</option>
                                <option>Matrimonio</option>
                                <option>Evento</option>
                                <option>Hotel / Ristorante</option>
                                <option>Regalo importante</option>
                                <option>Altro</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row-2">
                        <div class="field">
                            <label for="data">Data</label>
                            <input id="data" name="data" type="date">
                        </div>
                        <div class="field">
                            <label for="budget">Budget</label>
                            <select id="budget" name="budget">
                                <option value="">Seleziona…</option>
                                <option>Fino a €200</option>
                                <option>€200 – €500</option>
                                <option>€500 – €1.000</option>
                                <option>Oltre €1.000</option>
                                <option>Da definire</option>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label for="messaggio">Messaggio</label>
                        <textarea id="messaggio" name="messaggio" required placeholder="Raccontaci l'occasione, il luogo, la palette di colori che hai in mente…"></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Invia richiesta <span class="arrow" aria-hidden="true">→</span></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

{% endblock %}
